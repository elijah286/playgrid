# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Claude / local agent
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# supabase
supabase/.temp/
.supabase/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Generated App Store / Play Store screenshots — regenerable via
# `scripts/capture-store-screenshots.mjs`, large (~3 MB), not worth versioning.
# The icon + feature graphic under play-store/ ARE committed (small, hand-curated).
/public/marketing/store/

# Android Studio / IntelliJ project files — local, per-machine.
android/.idea/
