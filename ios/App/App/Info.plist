<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>xogridmaker</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- Force full screen on iPad: opt out of Split View / Slide Over / Stage
	     Manager windowing. The app is a single-WebView wrapper that's designed
	     phone-first; running it in a resizable iPad window adds no value and is
	     a suspected cause of the intermittent black WebView on iPad (WKWebView
	     can fail to composite when its window is resized). iPhone (always full
	     screen) has not shown the black screen; iPad (windowed) has. -->
	<key>UIRequiresFullScreen</key>
	<true/>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!-- Lets a silent (content-available) push wake the app in the background
	     so a dormant/never-reopened install can refresh a rotated APNs token
	     via /api/push/refresh (see AppDelegate didReceiveRemoteNotification). -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>xogridmaker tags your game sessions with the field you played at so you can review them later. Sharing your location is optional.</string>
	<!-- The @capacitor/geolocation plugin references the "Always" location
	     authorization API, so Apple's static scan (ITMS-90683) requires this
	     purpose string even though the app only ever requests "when in use"
	     location. The string is honest about that. -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>xogridmaker only uses your location while you’re using the app, to tag a game session with the field you’re playing at. It is never used in the background, and sharing your location is optional.</string>
	<key>NSCameraUsageDescription</key>
	<string>xogridmaker uses the camera so you can take a photo for your profile or team logo, or share a snapshot of a play sheet with Coach Cal.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>xogridmaker accesses your photo library so you can choose an image for your profile or team logo, or share a play sheet with Coach Cal.</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- App-Bound Domains: unlocks Service Workers (and other "powerful web
	     APIs") in the WKWebView for these registrable domains + subdomains.
	     Pairs with ios.limitsNavigationsToAppBoundDomains in
	     capacitor.config.ts — WebKit requires BOTH before it exposes
	     navigator.serviceWorker. The offline playbook feature (public/sw.js
	     caching /home and /offline/*) is dead on iOS without this. -->
	<key>WKAppBoundDomains</key>
	<array>
		<string>xogridmaker.com</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<!-- Reversed iOS OAuth client ID, required by the Google Sign-In
			     SDK so the auth redirect returns to the app. Must match the
			     iOS client ID configured in Site Admin (which the @capgo
			     SocialLogin plugin passes to GIDConfiguration at runtime). -->
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.624839566857-8ik9pdt7mv9sojjqn86cik8oc97kpvn6</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
